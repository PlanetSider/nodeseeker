# Compose 使用的镜像。固定版本示例：ghcr.io/planetsider/nodeseeker:v1.0
NODESEEKER_IMAGE=ghcr.io/planetsider/nodeseeker:latest

# 宿主机端口
PORT=3010

# 允许的跨域来源，多个值用逗号分隔
CORS_ORIGINS=http://localhost:3010

# RSS 请求超时，单位毫秒
RSS_TIMEOUT=10000

# 是否启用 RSS 定时任务
RSS_CHECK_ENABLED=true

# debug | info | warn | error
LOG_LEVEL=info

# 飞书 App ID、App Secret、Verification Token、RSS 地址、抓取间隔和代理
# 均通过 NodeSeeker Web 控制台配置并保存到 SQLite。
